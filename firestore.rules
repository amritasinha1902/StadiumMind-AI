rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    // Matches – public read, organizer/admin write
    match /matches/{matchId} {
      allow read: if true;
      allow write: if hasRole('organizer') || isAdmin();
    }

    // Incidents – authenticated read, security/admin write
    match /incidents/{incidentId} {
      allow read: if isAuthenticated();
      allow create: if hasRole('security') || isAdmin();
      allow update: if hasRole('security') || isAdmin();
      allow delete: if isAdmin();
    }

    // Tasks – authenticated read/update, organizer/admin create
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if hasRole('organizer') || isAdmin();
      allow update: if isAuthenticated();
      allow delete: if hasRole('organizer') || isAdmin();
    }

    // Venues – authenticated read, venue_operator/admin write
    match /venues/{venueId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('venue_operator') || isAdmin();
    }

    // Users – own document read/write
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Notifications – authenticated read, system write
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
